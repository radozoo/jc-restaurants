# Copy this file to `.env` (same folder) and fill in your values.
# `.env` is gitignored — NEVER commit it.
#
# Find these in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# The SERVICE ROLE key (secret!). It bypasses Row Level Security so these local
# scripts can write to `restaurants`. Used ONLY here on your machine — it must
# never appear in index.html or anywhere in the deployed site.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
